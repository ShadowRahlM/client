rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Messages: only authenticated admin can read; anyone can write (with validation)
    match /messages/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.message is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.email.size() > 0
                    && request.resource.data.message.size() > 0;
      allow read, update, delete: if request.auth != null && request.auth.token.email != null;
    }

    // Bookings: anyone can create; only admin can read
    match /bookings/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'service', 'date', 'time', 'createdAt']);
      allow read, update, delete: if request.auth != null && request.auth.token.email != null;
    }

    // Testimonials: anyone can read; only admin can write
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    // Site content (team, services, faq): anyone can read; only admin can write
    match /content/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
  }
}
