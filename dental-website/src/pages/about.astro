---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import TeamCard from '../components/TeamCard.astro';
import CTABanner from '../components/CTABanner.astro';

const team = [
  { name: 'Dr. Kaaki Emmanuel', role: 'Lead Dentist', bio: 'Over 10 years of experience in general and restorative dentistry. Dedicated to providing gentle, high-quality care for every patient.' },
  { name: 'Dr. Tumwine John', role: 'Orthodontist', bio: 'Specialist in braces and clear aligners. Passionate about creating confident smiles for patients of all ages.' },
  { name: 'Dr. Wanabuya Erickson', role: 'Cosmetic Specialist', bio: 'Expert in smile makeovers, veneers, and whitening. Transforms smiles with an artistic eye and precision technique.' },
];
---

<Layout
  title="About Us"
  description="Meet the team at Snow Dental Services. Experienced dental professionals dedicated to your oral health and smile."
>
  <Fragment slot="header"><Header /></Fragment>

  <Hero
    title="About Snow Dental Services"
    subtitle="Experienced professionals committed to your smile"
    image="https://images.pexels.com/photos/3845735/pexels-photo-3845735.jpeg?auto=compress&cs=tinysrgb&w=1920"
  />

  <!-- Our Story -->
  <section class="py-16 bg-white dark:bg-gray-800">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Our Story</h2>
      <div class="prose prose-gray dark:prose-invert max-w-none">
        <p>
          Snow Dental Services was founded with a simple mission: provide exceptional dental care in a
          warm, welcoming environment. We believe that a healthy smile transforms lives, and every patient
          deserves to feel heard, respected, and comfortable.
        </p>
        <p>
          Our practice combines modern dental technology with old-fashioned care. From routine cleanings
          to complex restorative procedures, we treat every patient like family.
        </p>
        <p>
          We are proud to serve our community with services ranging from general dentistry and orthodontics
          to cosmetic procedures and emergency care. Your smile is our priority.
        </p>
      </div>
      <div class="mt-8 rounded-xl overflow-hidden shadow-lg">
        <img src="https://images.pexels.com/photos/3845735/pexels-photo-3845735.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Snow Dental Services clinic" class="w-full h-auto" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-bold text-center text-gray-900 dark:text-white mb-2">Meet Our Team</h2>
      <p class="text-gray-600 dark:text-gray-400 text-center mb-10 max-w-lg mx-auto">
        Dedicated professionals who care about your smile
      </p>
      <div class="grid md:grid-cols-3 gap-8">
        {team.map(member => <TeamCard {...member} />)}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 bg-white dark:bg-gray-800">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 text-center">Our Values</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="text-center p-4">
          <div class="text-3xl mb-3">🫂</div>
          <h3 class="font-bold text-gray-900 dark:text-white mb-1">Compassion</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">We treat every patient with kindness and understanding</p>
        </div>
        <div class="text-center p-4">
          <div class="text-3xl mb-3">🔬</div>
          <h3 class="font-bold text-gray-900 dark:text-white mb-1">Excellence</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">We pursue the highest standards in dental care</p>
        </div>
        <div class="text-center p-4">
          <div class="text-3xl mb-3">🤝</div>
          <h3 class="font-bold text-gray-900 dark:text-white mb-1">Trust</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">We build lasting relationships through honesty and integrity</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner title="Meet Us in Person" description="Come visit our clinic and see why patients trust Snow Dental." />

  <Fragment slot="footer"><Footer /></Fragment>
</Layout>
