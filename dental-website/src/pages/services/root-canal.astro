---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<Layout
  title="Root Canal Treatment"
  description="Comfortable root canal therapy in Uganda. Save infected teeth and relieve pain at Snow Dental."
>
  <Fragment slot="header"><Header /></Fragment>
  <Hero title="Root Canal Treatment" subtitle="Save your tooth, relieve your pain" image="https://images.pexels.com/photos/3845737/pexels-photo-3845737.jpeg?auto=compress&cs=tinysrgb&w=1920" />

  <section class="py-16 bg-white dark:bg-gray-800">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="prose prose-gray dark:prose-invert max-w-none">
        <h2>What is Root Canal Treatment?</h2>
        <p>Root canal treatment removes infected or damaged pulp from inside the tooth, cleans and disinfects the canals, and seals the tooth. It saves teeth that would otherwise need extraction.</p>

        <h2>Signs You May Need a Root Canal</h2>
        <ul>
          <li>Severe tooth pain when chewing or applying pressure</li>
          <li>Prolonged sensitivity to hot or cold</li>
          <li>Darkening or discolouration of the tooth</li>
          <li>Swollen or tender gums near the tooth</li>
        </ul>

        <h2>What to Expect</h2>
        <p>Modern root canal treatment is comfortable and typically completed in 1-3 visits. We use local anaesthesia to ensure you feel no pain during the procedure.</p>
      </div>
    </div>
  </section>

  <CTABanner title="Relieve Your Pain" description="Don't let tooth pain wait. Book an appointment today." />
  <Fragment slot="footer"><Footer /></Fragment>
</Layout>
