---
import DarkModeToggle from './DarkModeToggle.astro';

const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About Us' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="bg-primary-800 dark:bg-gray-900 header-gradient sticky top-0 z-40 shadow-lg">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 text-white font-bold text-xl">
        <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 16c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7zm1-11.5c-.55 0-1 .45-1 1v4c0 .55.45 1 1 1h3c.55 0 1-.45 1-1s-.45-1-1-1h-2v-3c0-.55-.45-1-1-1z"/>
        </svg>
        <span>Snow Dental</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`text-sm font-medium transition-colors duration-200 ${
                currentPath === link.href
                  ? 'text-white border-b-2 border-white'
                  : 'text-white/80 hover:text-white'
              }`}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="tel:+256756350444"
          class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold text-white bg-white/20 hover:bg-white/30 rounded-lg px-3 py-1.5 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          0756-350-444
        </a>
        <a
          href="/book-online"
          class="bg-white text-primary-700 hover:bg-primary-50 font-bold text-sm px-4 py-2 rounded-lg transition-colors"
        >
          Book Now
        </a>
        <DarkModeToggle />
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-white" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-white/20">
    <div class="container mx-auto px-4 py-4 space-y-2">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`block py-2 text-sm font-medium ${
              currentPath === link.href ? 'text-white' : 'text-white/80 hover:text-white'
            }`}
          >
            {link.label}
          </a>
        ))
      }
      <a href="tel:+256756350444" class="block py-2 text-sm font-medium text-white/80 hover:text-white">
        Call: 0756-350-444
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-label', menu.classList.contains('hidden') ? 'Open menu' : 'Close menu');
    });
  }
</script>
