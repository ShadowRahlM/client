---
export interface Props {
  title: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  emergency?: boolean;
}

const { title, description, ctaText, ctaHref, emergency } = Astro.props;
---

<section class={`${emergency ? 'bg-red-600' : 'bg-primary-600'} text-white`}>
  <div class="container mx-auto px-4 py-12 text-center">
    <h2 class="text-2xl md:text-3xl font-bold mb-3">{title}</h2>
    {description && <p class="text-white/80 max-w-xl mx-auto mb-6">{description}</p>}
    <a
      href={ctaHref || '/book-online'}
      class={`inline-block font-bold px-8 py-3 rounded-lg transition-colors shadow-lg ${
        emergency
          ? 'bg-white text-red-600 hover:bg-red-50'
          : 'bg-white text-primary-700 hover:bg-primary-50'
      }`}
    >
      {ctaText || 'Book an Appointment'}
    </a>
  </div>
</section>
