---
export interface Props {
  quote: string;
  name: string;
  location?: string;
}

const { quote, name, location } = Astro.props;
---

<blockquote class="bg-white dark:bg-gray-800 rounded-xl shadow-md p-6 border border-gray-100 dark:border-gray-700">
  <svg class="w-8 h-8 text-primary-200 dark:text-primary-800 mb-2" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
  </svg>
  <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed italic mb-4">&ldquo;{quote}&rdquo;</p>
  <footer class="text-sm">
    <cite class="not-italic font-semibold text-gray-900 dark:text-white">{name}</cite>
    {location && <span class="text-gray-500 dark:text-gray-400"> &middot; {location}</span>}
  </footer>
</blockquote>
